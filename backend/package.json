    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "drizzle-kit": "^0.31.10",
    "pg": "^8.22.0",
    "prettier": "^3.8.4"
  },
  "peerDependencies": {
