{
	"name": "@mocinno/backend",
	"type": "module",
	"private": true,
	"trustedDependencies": [],
	"scripts": {
		"start": "NODE_ENV=production bun run --sql-preconnect src/index.ts",
		"dev": "bun run --sql-preconnect --watch src/index.ts",
		"bastion": "NODE_ENV=production bun run --sql-preconnect src/bastion.ts",
		"bastion:dev": "bun run --sql-preconnect --watch src/bastion.ts",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"email:dev": "email dev",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@react-email/ui": "6.0.5",
		"@shopify/prettier-plugin-liquid": "^1.10.3",
		"@types/bun": "^1.3.14",
		"@types/nodemailer": "^8.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/ssh2": "^1.15.5",
		"drizzle-kit": "^0.31.10",
		"pg": "^8.22.0",
		"prettier": "^3.8.4"
	},
	"peerDependencies": {
		"typescript": "catalog:"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.20",
		"@hono/trpc-server": "^0.4.2",
		"@trpc/client": "catalog:",
		"@trpc/server": "catalog:",
		"acme-client": "^5.4.0",
		"better-auth": "catalog:",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.27",
		"hono-sessions": "^0.8.1",
		"liquidjs": "^10.27.1",
		"nodemailer": "^9.0.1",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-email": "6.0.5",
		"ssh2": "^1.17.0",
		"tailwindcss": "^4.2.4",
		"superjson": "catalog:",
		"zod": "catalog:"
	},
	"overrides": {
		"cpu-features": "npm:@empty",
		"globals": "npm:globals@17.7.0",
		"react-email": {
			"@babel/traverse": {
				"globals": "npm:globals@17.7.0"
			}
		}
	},
	"exports": {
		".": {
			"import": "./src/index.ts"
		},
		"./trpc": {
			"import": "./src/routes/trpc/index.ts"
		},
		"./db": {
			"types": "./src/db/schema.ts"
		}
	}
}
